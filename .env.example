# Banco de dados (mesmo do sistema PHP - Atmun/sua hospedagem)
MYSQL_HOST=localhost
MYSQL_USER=seu_usuario
MYSQL_PASSWORD=sua_senha
MYSQL_DATABASE=nome_do_banco

# URL base do sistema PHP (onde está a API do agente)
BASE_URL=https://seusite.com.br/public
# Chave configurada em Configurações > IA Agendamento (campo "Chave da API (agente)")
API_KEY=sua_api_key_secreta

# Mesmo valor configurado na UI (Webhook > Código secreto)
WEBHOOK_SECRET=seu_webhook_secret

# Chave da OpenAI (ou configure na UI em IA Agendamento)
OPENAI_API_KEY=sk-...

# Porta (Render define PORT automaticamente)
PORT=10000
